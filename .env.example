# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Chat model for agent graph (LangChain). Default: gpt-5-mini
# OPENAI_MODEL=gpt-5-mini

# Optional: use a different model for title generation (e.g. gpt-5-mini for short outputs)
# OPENAI_TITLE_MODEL=gpt-5-mini

# LangSmith: tracing for Agentic mode uses LANGSMITH_API_KEY (and LANGSMITH_TRACING if needed)

# Agentic mode: web search (Tavily)
# TAVILY_API_KEY=your-tavily-api-key

# Agentic mode: vector search (Supabase Vector Buckets)
# VECTOR_BUCKET_NAME=book-embeddings
# VECTOR_INDEX_NAME=sections-openai

# Free beta: when set (e.g. 1 or true), all users get paid-tier access (unlimited uploads, AI).
# Usage section still shows real prices; nothing shown as "included".
# FREE_BETA_MODE=1

# Monetization: tier models (map to OpenAI model IDs)
# OPENAI_MODEL_ANONYMOUS=gpt-5-mini
# OPENAI_MODEL_FREE=gpt-5-mini
# OPENAI_MODEL_PAID=gpt-5.4

# Credits
# CREDITS_FREE_MONTHLY=5000
# CREDITS_PAID_MONTHLY=50000
# CREDITS_AGENTIC_ESTIMATE=100

# Stripe (paid tier)
# STRIPE_SECRET_KEY=sk_...
# STRIPE_WEBHOOK_SECRET=whsec_...  (for local: use secret from "stripe listen" output)
# STRIPE_PRICE_ID_PRO=price_...  (subscription)
# STRIPE_PRICE_ID_OVERAGE=price_...  (metered, for on-demand billing - create in Stripe Dashboard)
# CREDITS_OVERAGE_CENTS_PER_1000=10  (cents per 1000 on-demand credits, e.g. 10 = $0.10/1k = $1/10k)
