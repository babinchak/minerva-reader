# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Optional: use a different model for title generation (e.g. gpt-4o-mini) if your main model (e.g. o1) is poor at short outputs
# OPENAI_TITLE_MODEL=gpt-4o-mini

# LangSmith: tracing for Agentic mode uses LANGSMITH_API_KEY (and LANGSMITH_TRACING if needed)

# Agentic mode: web search (Tavily)
# TAVILY_API_KEY=your-tavily-api-key

# Agentic mode: vector search (Supabase Vector Buckets)
# VECTOR_BUCKET_NAME=book-embeddings
# VECTOR_INDEX_NAME=sections-openai

# Monetization: tier models (map to OpenAI model IDs)
# OPENAI_MODEL_ANONYMOUS=gpt-4o-mini
# OPENAI_MODEL_FREE=gpt-4o-mini
# OPENAI_MODEL_PAID=gpt-4o

# Credits
# CREDITS_FREE_MONTHLY=5000
# CREDITS_PAID_MONTHLY=50000
# CREDITS_AGENTIC_ESTIMATE=100

# Stripe (paid tier and top-ups)
# STRIPE_SECRET_KEY=sk_...
# STRIPE_WEBHOOK_SECRET=whsec_...  (for local: use secret from "stripe listen" output)
# STRIPE_PRICE_ID_PRO=price_...  (subscription)
# STRIPE_PRICE_ID_TOPUP=price_...  (one-time, 25k credits)
